# Relive 生产环境配置（使用 DockerHub 镜像）
# 使用方法：make prod 或 docker-compose -f docker-compose.prod.yml up -d

services:
  relive:
    image: davidhu/relive:latest
    container_name: relive
    restart: unless-stopped
    ports:
      - "8080:8080"
    volumes:
      # 配置文件
      - ./backend/config.prod.yaml:/app/config.yaml:ro
      # 数据目录（数据库、日志）
      - ./data/backend:/app/data
      # =============================================================================
      # 离线逆地理编码数据（可选）
      # =============================================================================
      # 下载 cities500.zip 并解压到 ./data/backend/ 目录
      # 容器启动时会自动检测并导入
      # =============================================================================
      # 照片目录挂载
      # =============================================================================
      # 使用方法：
      # 1. 修改下方的宿主机路径（冒号左边）为你实际的照片目录
      # 2. 容器内路径（冒号右边）保持 /app/photos 不变
      # 3. 在 Web 界面中添加扫描路径时使用容器内路径：/app/photos
      #
      # 示例：
      # - /Users/yourname/Pictures:/app/photos:ro
      # - /volume1/photos:/app/photos:ro
      # =============================================================================
      # - ./data/photos:/app/photos:ro
    environment:
      - TZ=Asia/Shanghai
      - JWT_SECRET=${JWT_SECRET}
      # AI Provider API Keys（如果使用）
      - QWEN_API_KEY=${QWEN_API_KEY:-}
      - OPENAI_API_KEY=${OPENAI_API_KEY:-}
      # 自动导入城市数据（默认开启，首次启动时会自动导入 cities500.txt）
      - AUTO_IMPORT_CITIES=${AUTO_IMPORT_CITIES:-true}
    networks:
      - relive-network
    healthcheck:
      test: ["CMD", "wget", "--no-verbose", "--tries=1", "--spider", "http://localhost:8080/api/v1/system/health"]
      interval: 30s
      timeout: 3s
      retries: 3
      start_period: 10s
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "3"

networks:
  relive-network:
    driver: bridge
