# Relive 配置文件示例
# 复制此文件为 .env 并填入实际配置

# 数据库
DATABASE_URL=sqlite:///./relive.db

# NAS 配置
NAS_PHOTO_PATH=/path/to/your/nas/photos

# Qwen API 配置
QWEN_API_KEY=your_api_key_here
QWEN_API_URL=https://dashscope.aliyuncs.com/api/v1/services/aigc/multimodal-generation/generation
QWEN_MODEL=qwen-vl-max

# API 服务
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=True

# 评分阈值
MIN_ART_SCORE=60
MIN_MEMORY_SCORE=70
