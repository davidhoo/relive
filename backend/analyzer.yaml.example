# relive-analyzer API 模式配置示例
# 复制此文件为 analyzer.yaml 并填写实际值
server:
  endpoint: "http://localhost:8080"
  api_key: "${RELIVE_API_KEY}"  # 从配置页面生成的 API Key
  timeout: 30

analyzer:
  workers: 2
  fetch_limit: 5
  retry_count: 3
  retry_delay: 5
  checkpoint_file: "./data/analyzer-checkpoint.db"

ai:
  provider: "vllm"
  vllm:
    endpoint: "${VLLM_ENDPOINT}"  # 例如: http://localhost:8028
    model: "${VLLM_MODEL}"  # 例如: /path/to/your/model 或 Qwen/Qwen3.5-9B"
    temperature: 0.7
    timeout: 60

download:
  temp_dir: "./data/analyzer-temp"
  timeout: 60
  max_concurrent: 3
  retry_count: 3
  keep_temp: false

batch:
  size: 5
  flush_interval: 30
  max_retry: 3
  retry_delay: 5

logging:
  level: "debug"
  console: true
  file: "./data/logs/analyzer.log"
