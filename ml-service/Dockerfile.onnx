# Stage 1: Export ONNX model (uses PyTorch, cached after first build)
FROM python:3.12-slim AS exporter

WORKDIR /app

# Install PyTorch and dependencies for export (this layer is cached)
RUN pip install --no-cache-dir \
    torch>=2.0 \
    torchvision>=0.15 \
    timm>=1.0 \
    pytorch-lightning>=2.0 \
    huggingface_hub>=0.20 \
    loguru>=0.7 \
    Pillow>=10.0 \
    onnx>=1.15 \
    onnxruntime>=1.16 \
    onnxscript

# Copy model code
COPY app/models/orientation_cgd /app/app/models/orientation_cgd

# Copy and run export script (only re-runs if export_to_onnx.py changes)
COPY export_to_onnx.py /app/
RUN python export_to_onnx.py --output /orientation_model.onnx

# Stage 2: Runtime image (ONNX Runtime only, ~300MB)
FROM python:3.12-slim

WORKDIR /app

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1
ENV INSIGHTFACE_HOME=/app/models

# Install only runtime dependencies (no PyTorch!)
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    libgl1 \
    libglib2.0-0 \
    && rm -rf /var/lib/apt/lists/*

# Install minimal dependencies
COPY requirements-onnx.txt .
RUN pip install --no-cache-dir -r requirements-onnx.txt

# Copy application code
COPY app ./app

# Copy ONNX model from exporter stage (use different path to avoid volume conflict)
COPY --from=exporter /orientation_model.onnx /app/onnx_models/orientation_model.onnx

EXPOSE 5050

CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "5050"]
