# Relive 环境变量配置

# AI Provider API Keys
# 如果使用 Qwen API
QWEN_API_KEY=

# 如果使用 OpenAI API
OPENAI_API_KEY=

# JWT Secret（生产环境必须修改）
JWT_SECRET=relive-production-secret-please-change-me

# =============================================================================
# 照片目录路径配置（Docker 多路径支持）
# =============================================================================
#
# 说明：Docker 容器无法直接访问宿主机路径，需要通过 volume 挂载。
# 以下配置支持最多 4 个照片目录路径。
#
# 挂载点对应关系：
# - PHOTOS_PATH         -> 容器内 /app/photos
# - EXTRA_PHOTOS_PATH_1 -> 容器内 /app/photos_extra1
# - EXTRA_PHOTOS_PATH_2 -> 容器内 /app/photos_extra2
# - EXTRA_PHOTOS_PATH_3 -> 容器内 /app/photos_extra3
#
# 在 Web 界面中添加扫描路径时，请使用容器内路径：
#   /app/photos        (对应主路径)
#   /app/photos_extra1 (对应额外路径1)
#   /app/photos_extra2 (对应额外路径2)
#   /app/photos_extra3 (对应额外路径3)
#
# =============================================================================

# 主照片路径（默认路径）
PHOTOS_PATH=./data/photos

# 额外的照片路径（可选，不需要时保持注释或删除）
# EXTRA_PHOTOS_PATH_1=/path/to/your/photos1
# EXTRA_PHOTOS_PATH_2=/path/to/your/photos2
# EXTRA_PHOTOS_PATH_3=/path/to/your/photos3

# =============================================================================

# 前端端口
FRONTEND_PORT=8888

# 后端端口
BACKEND_PORT=8080
