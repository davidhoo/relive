 */

#ifndef CONFIG_LOCAL_H
#define CONFIG_LOCAL_H

// ============ WiFi 配置 ============
#define WIFI_SSID           "your-wifi-ssid"
#define WIFI_PASSWORD       "your-wifi-password"

// 自定义 MAC 地址（可选）
// 格式: {0xAA, 0xBB, 0xCC, 0xDD, 0xEE, 0xFF}
// 取消注释下一行并设置 MAC 地址以启用
// #define WIFI_CUSTOM_MAC     {0x00, 0x00, 0x00, 0x00, 0x00, 0x00}

// ============ API 配置 ============
// 服务器地址（可以是 IP 或域名）
#define API_BASE_URL        "http://192.168.1.100:8080/api/v1"

// 设备 API Key（从 Relive 后端获取）
#define DEVICE_API_KEY      "sk-relive-your-device-api-key"

#endif // CONFIG_LOCAL_H
